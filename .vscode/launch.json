{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Prodwatch",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "web.starlette_app:app",
                "--reload",
                "--log-level", "debug"
            ],
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "VIRTUAL_ENV": "${workspaceFolder}/.venv",
                "PATH": "${workspaceFolder}/.venv/bin:${env:PATH}"
            },
            "python": "${workspaceFolder}/.venv/bin/python"
        }
    ]
}